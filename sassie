#!/usr/bin/env python3

from colorsys import rgb_to_hls
from PIL import Image, ImageOps, ImageFilter, ExifTags
from sys import exit, argv
import argparse
from re import split
from copy import deepcopy
from potrace import Bitmap, POTRACE_TURNPOLICY_MINORITY, POTRACE_TURNPOLICY_MAJORITY, POTRACE_TURNPOLICY_BLACK, POTRACE_TURNPOLICY_WHITE
from wand.image import Image as WandImage
from io import BytesIO


# Handle resampling for multiple PIL versions
# Thanks! https://stackoverflow.com/a/73000977
if not hasattr(Image, 'Resampling'):  # Pillow<9.0
    Image.Resampling = Image


class sassie:
    """
    Reduce image colors palette to specified palette and convert to svg
    """

    def traces_to_svg(self, traces, width, height, vb_width=None, vb_height=None, background_color=None, textbox=None):
        """
        vb_width/vb_height are the viewBox dimensions (coordinate space of the traced paths).
        width/height are the rendered output dimensions.
        Keeping these separate allows scaling without cropping.
        """

        if vb_width is None:
            vb_width = width
        if vb_height is None:
            vb_height = height

        font_name = None

        svg = f'''<svg version="1.1" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" width="{width}" height="{height}" viewBox="0 0 {vb_width} {vb_height}">'''

        svg += '<!-- Generated using https://github.com/oliverfields/sassie -->'

        svg += f'<!-- Arguments: {" ".join(argv[1:])}  -->'

        if textbox:
            font_name = self.resolve_font(self, textbox.get('font', None))

        if background_color:
            svg += f'<rect width="100%" height="100%" fill="#{background_color}" />'

        # Wrap each layer path in a named group for animation targeting
        for layer_index, trace in enumerate(traces):
            svg += self.trace_to_svg_part(self, trace['trace'], trace['hex_color'], layer_index)

        if textbox:
            try:
                text = textbox['text'].split('\n')
                text_line_count = len(text)
            except Exception as e:
                text = []
                text_line_count = 0
                print(str(e))
                raise

            lightest = max(self.colors, key=lambda c: c['hls'][1])['hex']
            darkest  = min(self.colors, key=lambda c: c['hls'][1])['hex']

            if 'fill' in textbox:
                val = textbox['fill'].strip()
                fill = None if val == 'none' else (lightest if val == '' else val.lstrip('#'))
            else:
                fill = lightest

            if 'stroke' in textbox:
                val = textbox['stroke'].strip()
                stroke = None if val == 'none' else (darkest if val == '' else val.lstrip('#'))
            else:
                stroke = darkest

            stroke_width = textbox.get('stroke-width', 1)

            # margin in em units (multiples of font-size), converted to px
            # font-size must be resolved first — use a temp value for the margin calc
            # then recalculate margin once final font-size is known
            margin_em = textbox.get('margin', 1.0)

            font_size_setting = textbox.get('font-size', 'auto')
            if font_size_setting == 'auto' or 'font-size' not in textbox:
                # Auto-fit: find largest font size where the longest line fits the width
                margin_px = margin_em * 32  # temp estimate
                max_width = vb_width - 2 * margin_px
                longest   = max(textbox['text'].split('\n'), key=len)
                ratio     = textbox.get('font-width-ratio', 0.55)
                font_size = int(max_width / max(len(longest), 1) / ratio)
                font_size = max(12, min(font_size, 400))
            else:
                font_size = int(font_size_setting)

            margin = margin_em * font_size

            text_anchor  = 'middle'
            text_baseline = 'middle'
            text_height  = text_line_count * font_size

            # x/y defaults — gravity may override, explicit x/y overrides gravity
            # Uses vb_width/vb_height (viewBox/coordinate space), not output dimensions
            x = int(vb_width / 2)
            y = int(vb_height / 2)

            gravity = textbox.get('gravity', None)
            if gravity:
                if gravity == 'c':
                    x = int(vb_width / 2)
                    y = int(vb_height / 2) - int(text_height / 2) + int(font_size / 2)
                    text_anchor  = 'middle'
                    text_baseline = 'middle'
                elif gravity == 'n':
                    x = int(vb_width / 2)
                    y = int(margin + font_size)
                    text_anchor  = 'middle'
                    text_baseline = 'ideographic'
                elif gravity == 'ne':
                    x = int(vb_width - margin)
                    y = int(margin + font_size)
                    text_anchor  = 'end'
                    text_baseline = 'ideographic'
                elif gravity == 'e':
                    x = int(vb_width - margin)
                    y = int(vb_height / 2) - int(text_height / 2) + int(font_size / 2)
                    text_anchor  = 'end'
                    text_baseline = 'middle'
                elif gravity == 'se':
                    x = int(vb_width - margin)
                    y = int(vb_height - text_height - margin + font_size)
                    text_anchor  = 'end'
                    text_baseline = 'after-edge'
                elif gravity == 's':
                    x = int(vb_width / 2)
                    y = int(vb_height - text_height - margin + font_size)
                    text_anchor  = 'middle'
                    text_baseline = 'after-edge'
                elif gravity == 'sw':
                    x = int(margin)
                    y = int(vb_height - text_height - margin + font_size)
                    text_anchor  = 'start'
                    text_baseline = 'after-edge'
                elif gravity == 'w':
                    x = int(margin)
                    y = int(vb_height / 2) - int(text_height / 2) + int(font_size / 2)
                    text_anchor  = 'start'
                    text_baseline = 'middle'
                elif gravity == 'nw':
                    x = int(margin)
                    y = int(margin + font_size)
                    text_anchor  = 'start'
                    text_baseline = 'ideographic'
                else:
                    print(f"Textbox gravity '{gravity}' unknown, must be c, n, ne, e, se, s, sw, w or nw")

            # Explicit x/y always win over gravity
            if 'x' in textbox:
                x = textbox['x']
            if 'y' in textbox:
                y = textbox['y']

            font_family = f' font-family="{font_name}"' if font_name else ''

            if len(text) > 1:
                text_baseline = 'hanging'
                text_y = y - int(text_height / 2)
            else:
                text_y = y

            # Wrap all text lines in a single named group for animate.py targeting
            fill_attr   = f' fill="#{fill}"'     if fill   else ' fill="none"'
            stroke_attr = f' stroke="#{stroke}" stroke-width="{stroke_width}"' if stroke else ''
            svg += '<g id="text-0">'
            line_count = 0
            line_y = text_y
            for t in text:
                svg += (
                    f'<g{fill_attr}{stroke_attr}>'
                    f'<text font-size="{font_size}"{font_family} x="{x}" y="{line_y}" '
                    f'dominant-baseline="{text_baseline}" text-anchor="{text_anchor}">'
                    f'{t}</text></g>'
                )
                line_count += 1
                line_y = text_y + (line_count * font_size)
            svg += '</g>'


        svg += "</svg>"

        return svg


    def trace_to_svg_part(self, trace, fill_color, layer_index=None):
        parts = []
        for curve in trace:
            fs = curve.start_point
            parts.append(f"M{fs.x},{fs.y}")
            for segment in curve.segments:
                if segment.is_corner:
                    a = segment.c
                    b = segment.end_point
                    parts.append(f"L{a.x},{a.y}L{b.x},{b.y}")
                else:
                    a = segment.c1
                    b = segment.c2
                    c = segment.end_point
                    parts.append(f"C{a.x},{a.y} {b.x},{b.y} {c.x},{c.y}")
            parts.append("z")

        path = f'<path stroke="none" fill="#{fill_color}" fill-rule="evenodd" d="{"".join(parts)}"/>'

        if layer_index is not None:
            return f'<g id="layer-{layer_index}" data-color="#{fill_color}">{path}</g>'
        else:
            return path


    def resolve_font(self, font):
        """
        Accept a font name ("Times New Roman") or a file path ("/path/to/font.ttf").
        Returns a font-family string suitable for SVG, or None if nothing was provided.
        For a font name, uses fc-match to verify it exists on the system.
        For a file path, checks the file exists.
        """
        import subprocess, os

        if not font:
            return None

        # Looks like a file path
        if os.sep in font or font.endswith(('.ttf', '.otf', '.TTF', '.OTF')):
            if os.path.isfile(font):
                return font
            else:
                print(f'Font file not found: {font}')
                return None

        # Treat as a font name — use fc-match to verify it exists on the system
        try:
            result = subprocess.run(
                ['fc-match', font, '--format=%{family}'],
                capture_output=True, text=True
            )
            matched = result.stdout.strip()
            if matched:
                return font  # pass name through; cairosvg resolves via fontconfig
            else:
                print(f'Font not found: {font}')
                return None
        except FileNotFoundError:
            # fc-match not available (non-Linux), pass name and hope for the best
            return font


    def filter_by_color(self, color, image):
        """
        Return image where all colors except color are white and color is black
        """

        old_palette = image.getpalette()
        new_palette = []
        for i in range(0, len(old_palette), 3):
            if old_palette[i] == color[0] and old_palette[i+1] == color[1] and old_palette[i+2] == color[2]:
                new_palette.append(0)
                new_palette.append(0)
                new_palette.append(0)
            else:
                new_palette.append(255)
                new_palette.append(255)
                new_palette.append(255)

        try:
            new_image = deepcopy(image)
            new_image.putpalette(new_palette)
        except Exception as e:
            print(str(e))

        return new_image


    def __new__(self, hex_colors, image_src, turd_size=0, sort_palette=False, mode_filter_size=None, textbox=None, width=None, height=None, resize=False):
        self.colors = []
        tmp_colors = []
        grayscale_colors = []

        for c in hex_colors:
            r, g, b = self.hex2rgb(self, c)
            tmp_colors.append({
                'hex': c,
                'rgb': (r, g ,b),
                'hls': rgb_to_hls(r, g, b),
            })

        # Sort colors by V value of HSV to arrange them from from dark to light
        if sort_palette:
            for c in sorted(tmp_colors, key=lambda x: x['hls'][1], reverse=True):
                self.colors.append(c)
        else:
            self.colors = tmp_colors

        try:
            img = Image.open(image_src)
        except Exception as e:
            raise Exception('Unable to open image: ' + image_src + ': ' + str(e))

        if resize:
            if img.width > 1920 or img.height > 1920:

                small_width = 1920
                wpercent = (small_width / float(img.width))
                small_height = int((float(img.height) * float(wpercent)))
                print(f'Resizing to {small_width}x{small_height}. Use -n or --no-resize to disable this behaviour')
                img.thumbnail((small_width, small_height), Image.Resampling.LANCZOS)

            # Rotate image if has exif orientation tag
            # Thanks! https://stackoverflow.com/a/26928142
            try:
                for orientation in ExifTags.TAGS.keys():
                    if ExifTags.TAGS[orientation] == 'Orientation':
                        break
                exif = img._getexif()

                if exif[orientation] == 3:
                    img = img.rotate(180, expand=True)
                elif exif[orientation] == 6:
                    img = img.rotate(270, expand=True)
                elif exif[orientation] == 8:
                    img = img.rotate(90, expand=True)

            except (TypeError, AttributeError, KeyError, IndexError):
                # cases: image don't have getexif
                pass

        try:
            img = ImageOps.grayscale(img)
        except Exception as e:
            raise Exception('Unable to convert image to grayscale: ' + image_src + ': ' + str(e))


        # Reduce palette to number of color argument
        try:
            img = img.convert('P', palette=Image.ADAPTIVE, colors=len(hex_colors))
        except Exception as e:
            raise Exception('Unable to reduce palette: ' + image_src + ': ' + str(e))


        # Despecle image
        if mode_filter_size == None:
            w, h = img.size
            mode_filter_size = int(w * h * 0.00001)

        img = img.filter(ImageFilter.ModeFilter(size=mode_filter_size))


        # For each supplied color match to corresponding grayscale color
        grayscale_colors = img.getpalette()[:len(hex_colors) * 3]
        colors_index = 0
        for i in range(0, len(hex_colors) * 3, 3):
            self.colors[colors_index]['grayscale_hex'] = '%02x%02x%02x' % (grayscale_colors[i], grayscale_colors[i+1], grayscale_colors[i+2])
            self.colors[colors_index]['grayscale_rgb'] = (grayscale_colors[i], grayscale_colors[i+1], grayscale_colors[i+2])
            colors_index += 1

        gs_palette = img.getpalette()

        layers_bitmap = []
        layers_trace = []

        # Replace image grayscale colors with supplied palette
        for n in range(0, len(self.colors) * 3, 3):
            for i in range(0, len(self.colors)):
                if gs_palette[n] == self.colors[i]['grayscale_rgb'][0] and gs_palette[n+1] == self.colors[i]['grayscale_rgb'][1] and gs_palette[n+2] == self.colors[i]['grayscale_rgb'][2]:

                    layers_bitmap.append({
                        'hex_color': self.colors[i]['hex'],
                        'bitmap': self.filter_by_color(self, self.colors[i]['grayscale_rgb'], img)
                    })

                    break

        # Trace bitmap layers as paths
        for l in layers_bitmap:
            bitmap = Bitmap(l['bitmap'])
            layers_trace.append({
                'hex_color': l['hex_color'],
                'trace': bitmap.trace(
                    turdsize=turd_size,
                    turnpolicy=POTRACE_TURNPOLICY_BLACK,
                    alphamax=1.3334,
                )
            })

        # The image's actual pixel dimensions define the SVG coordinate space
        # (viewBox). The -w/-e arguments control the rendered output size only.
        img_width = img.size[0]
        img_height = img.size[1]

        out_width = width if width else img_width
        out_height = height if height else img_height

        svg = self.traces_to_svg(
            self,
            layers_trace,
            out_width,
            out_height,
            vb_width=img_width,
            vb_height=img_height,
            background_color=self.colors[-1]['hex'],
            textbox=textbox,
        )

        return svg


    def hex2rgb(self, hex_color):

        # Remove the '#' character if present
        hex_color = hex_color.lstrip('#')

        # Convert hex to RGB
        r, g, b = [int(hex_color[i:i+2], 16) for i in (0, 2, 4)]

        return (r, g, b)


if __name__ == "__main__":

    textbox = None
    p = argparse.ArgumentParser(description='reduction of realism for the increase of love', epilog='Example --textbox JSON: { "text": "Two in times\\nof peace", "fill": "red", "stroke": "white", "font-size": 60, "font": "/usr/share/fonts/truetype/dejavu/DejaVuSans.ttf", "x": 210, "y": 100}')

    p.add_argument('-m', '--mode-filter-size', action='store', type=int, help='Replace the pixel value with the median value of all pixels within the given size')
    p.add_argument('-w', '--width', action='store', type=int, help='SVG width')
    p.add_argument('-e', '--height', action='store', type=int, help='SVG height')
    p.add_argument('-d', '--turd-size', action='store', type=int, help='Despeckle the bitmap to be traced, by removing all curves whose enclosed area is below the given threshold', default=0)
    p.add_argument('-p', '--hex-palette', action='store', type=str, help='Hex color codes separated by space or dash', required=True)
    p.add_argument('-o', '--output', action='store', type=str, help='Output file path', required=True)
    p.add_argument('-f', '--font', action='store', type=str, help='Font name ("Times New Roman") or path to a TTF/OTF file')
    p.add_argument('-t', '--textbox', action='store', type=str, help='text box settings (JSON)', default=None)
    p.add_argument('-s', '--sort-palette', action='store_true', help='Sort palette dark to light')
    p.add_argument('-n', '--no-resize', action='store_true', help='Disable resizing of large images')
    p.add_argument('file', nargs=argparse.PARSER)
    a = p.parse_args()

    hex_colors = a.hex_palette.replace('#', '')
    hex_colors = hex_colors.lower()
    hex_colors = hex_colors.replace('-', ' ')
    hex_colors = split(' ', hex_colors)

    try:
        if a.textbox:
            textbox = eval(a.textbox)
    except Exception as e:
        print('Unable to parse textbox setting string')
        exit(1)

    if a.no_resize:
        resize = False
    else:
        resize = True

    try:
        svg = sassie(hex_colors, a.file[0], mode_filter_size=a.mode_filter_size, sort_palette=a.sort_palette, textbox=textbox, height=a.height, width=a.width, resize=resize, turd_size=a.turd_size)
    except Exception as e:
        print('Image processing failed: ' + str(e))
        exit(1)

    if a.output.endswith('.svg'):
        try:
            with open(f"{a.output}", "w") as fp:
                fp.write(svg)
        except Exception as e:
            print(f'Unable to save: {a.output}: ' + str(e))
            exit(1)
    elif a.output.endswith('.png'):
        try:
            svg_bytes = BytesIO(svg.encode('utf-8'))
            with WandImage(file=svg_bytes, format='svg') as png:
                png.save(filename=f"{a.output}")
        except Exception as e:
            print(f'Unable to save: {a.output}: ' + str(e))
            exit(1)
    else:
        print('Illegal file type, must be .svg or .png')
        exit(1)

    exit(0)
